<%- include('header') %>
<div class="flex items-center justify-between mb-6">
  <h1 class="font-headline-md text-headline-md text-on-surface">Alertas de deuda</h1>
</div>
<% if (alertas.length === 0) { %>
<div class="mt-12 p-8 border-2 border-dashed border-outline-variant rounded-2xl flex flex-col items-center justify-center text-center">
  <div class="w-16 h-16 bg-surface-container-high rounded-full flex items-center justify-center mb-4">
    <span class="material-symbols-outlined text-success-payment text-[32px]">check_circle</span>
  </div>
  <h4 class="font-headline-sm text-headline-sm text-on-surface">No hay deudas pendientes</h4>
  <p class="text-on-surface-variant max-w-xs mt-2">Todos los participantes están al día.</p>
</div>
<% } else { %>
<div class="space-y-4">
  <% alertas.forEach(a => { %>
    <a href="/juntas/<%= a.junta_id %>" class="group bg-surface-container-lowest border border-outline-variant/40 rounded-xl p-5 hover:border-error-alert/50 transition-all shadow-sm hover:shadow-md cursor-pointer block">
      <div class="flex items-start justify-between gap-4">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-lg bg-error-container flex items-center justify-center text-error-alert">
            <span class="material-symbols-outlined text-[24px]">warning</span>
          </div>
          <div>
            <h4 class="font-headline-sm text-headline-sm text-on-surface"><%= a.participante_nombre %></h4>
            <p class="font-body-md text-body-md text-on-surface-variant">Debe en <strong><%= a.junta_nombre %></strong> (ciclo <%= a.ciclo_numero %>)</p>
            <p class="font-label-sm text-label-sm text-error-alert font-medium mt-1">S/ <%= a.monto_aporte %> pendiente</p>
          </div>
        </div>
        <span class="px-3 py-1 rounded-full bg-error-container text-on-error-container font-label-sm text-label-sm font-bold whitespace-nowrap"><%= a.dias_atraso || '?' %> días</span>
      </div>
    </a>
  <% }) %>
</div>
<% } %>
<%- include('footer') %>
