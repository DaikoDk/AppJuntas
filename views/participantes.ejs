<%- include('header') %>
<div class="flex items-center justify-between mb-8">
  <div>
    <h1 class="font-headline-md text-headline-md-mobile md:text-headline-md text-on-surface">Participantes</h1>
    <p class="text-on-surface-variant font-label-md">Gestiona los miembros de tu comunidad de ahorro.</p>
  </div>
  <button class="bg-primary text-on-primary px-6 py-3 rounded-xl font-label-md flex items-center gap-2 shadow-lg shadow-primary/20 hover:bg-primary-container transition-all active:scale-95" onclick="toggleModal('addParticipantModal')">
    <span class="material-symbols-outlined text-[20px]">person_add</span>
    Agregar
  </button>
</div>
<% if (sin_participantes) { %>
<div class="bg-warning-debt/10 border border-warning-debt/20 rounded-xl p-4 flex items-center gap-3 mb-4">
  <span class="material-symbols-outlined text-warning-debt">warning</span>
  <p class="font-body-md text-body-md text-on-surface-variant">Crea al menos un participante antes de crear una junta.</p>
</div>
<% } %>
<% if (error === 'nombre_vacio') { %>
<div class="bg-error-container border border-error-container rounded-xl p-4 flex items-center gap-3 mb-4">
  <span class="material-symbols-outlined text-error-alert">warning</span>
  <p class="font-body-md text-body-md text-on-surface-variant">El nombre del participante es obligatorio.</p>
</div>
<% } else if (error === 'telefono_vacio') { %>
<div class="bg-error-container border border-error-container rounded-xl p-4 flex items-center gap-3 mb-4">
  <span class="material-symbols-outlined text-error-alert">warning</span>
  <p class="font-body-md text-body-md text-on-surface-variant">El teléfono es obligatorio para recibir notificaciones.</p>
</div>
<% } else if (error === 'telefono_duplicado') { %>
<div class="bg-error-container border border-error-container rounded-xl p-4 flex items-center gap-3 mb-4">
  <span class="material-symbols-outlined text-error-alert">warning</span>
  <p class="font-body-md text-body-md text-on-surface-variant">Ese número de teléfono ya está registrado por otro participante.</p>
</div>
<% } else if (error === 'no_encontrado') { %>
<div class="bg-error-container border border-error-container rounded-xl p-4 flex items-center gap-3 mb-4">
  <span class="material-symbols-outlined text-error-alert">warning</span>
  <p class="font-body-md text-body-md text-on-surface-variant">El participante no existe o no tienes permiso para editarlo.</p>
</div>
<% } else if (error === 'id_invalido') { %>
<div class="bg-error-container border border-error-container rounded-xl p-4 flex items-center gap-3 mb-4">
  <span class="material-symbols-outlined text-error-alert">warning</span>
  <p class="font-body-md text-body-md text-on-surface-variant">ID de participante inválido.</p>
</div>
<% } %>
<div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
  <% participantes.forEach(p => { %>
    <div class="bg-surface-container-lowest p-6 rounded-xl border border-outline-variant hover:border-primary/30 transition-all group relative overflow-hidden">
      <div class="flex items-start justify-between relative z-10">
        <div class="flex gap-4">
          <div class="w-12 h-12 rounded-lg bg-surface-container-high flex items-center justify-center text-primary font-bold"><%= p.nombre.charAt(0).toUpperCase() %></div>
          <div>
            <h3 class="font-headline-sm text-headline-sm text-on-surface group-hover:text-primary transition-colors"><%= p.nombre %></h3>
            <p class="font-body-md text-body-md text-on-surface-variant flex items-center gap-1 mt-1">
              <span class="material-symbols-outlined text-[16px]"><%= p.telefono ? 'call' : 'call_end' %></span>
              <%= p.telefono || 'Sin teléfono' %>
            </p>
          </div>
        </div>
        <div class="flex gap-1">
          <button onclick="editar(<%= p.id %>, '<%= p.nombre.replace(/'/g, "\\'") %>', '<%= (p.telefono || '').replace(/'/g, "\\'") %>')" class="p-2 text-outline hover:text-primary hover:bg-primary/10 rounded-lg transition-all active:scale-90">
            <span class="material-symbols-outlined">edit</span>
          </button>
          <% if (!p.google_id) { %>
          <form method="POST" action="/participantes/eliminar/<%= p.id %>" onsubmit="return confirm('¿Eliminar?')">
            <button type="submit" class="p-2 text-outline hover:text-error hover:bg-error-container/50 rounded-lg transition-all active:scale-90">
              <span class="material-symbols-outlined">delete</span>
            </button>
          </form>
          <% } %>
        </div>
      </div>
      <div class="mt-4 pt-4 border-t border-surface-container-high flex gap-2">
        <span class="px-3 py-1 bg-surface-container rounded-full font-label-sm text-secondary">Activo</span>
        <span class="px-3 py-1 bg-primary/5 rounded-full font-label-sm text-primary">Ahorrador</span>
      </div>
      <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-primary/5 rounded-full blur-2xl group-hover:bg-primary/10 transition-all"></div>
    </div>
  <% }) %>
  <!-- Add New Quick Action Card -->
  <button class="bg-primary/5 p-6 rounded-xl border-2 border-dashed border-primary/20 hover:border-primary/40 flex flex-col items-center justify-center gap-2 group transition-all" onclick="toggleModal('addParticipantModal')">
    <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center text-primary group-hover:scale-110 transition-transform">
      <span class="material-symbols-outlined">add</span>
    </div>
    <p class="font-label-md text-label-md text-primary">Agregar nuevo participante</p>
  </button>
</div>
<!-- Add Participant Modal -->
<div class="fixed inset-0 z-[60] hidden" id="addParticipantModal">
  <div class="absolute inset-0 bg-on-surface/40 premium-blur" onclick="toggleModal('addParticipantModal')"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md p-margin-mobile">
    <div class="bg-surface-container-lowest rounded-xl shadow-2xl p-8 space-y-6">
      <div class="flex justify-between items-center">
        <h2 class="font-headline-md text-headline-md text-on-surface">Nuevo Participante</h2>
        <button class="text-outline hover:text-on-surface" onclick="toggleModal('addParticipantModal')"><span class="material-symbols-outlined">close</span></button>
      </div>
      <form method="POST" action="/participantes/nuevo" class="space-y-4">
        <div class="space-y-1">
          <label class="font-label-md text-label-md text-on-surface-variant ml-1">Nombre completo</label>
          <input type="text" name="nombre" required class="w-full bg-surface-light border border-outline-variant rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" placeholder="Ej: Juan Pérez">
        </div>
        <div class="space-y-1">
          <label class="font-label-md text-label-md text-on-surface-variant ml-1">Teléfono <span class="text-error-alert">*</span></label>
          <input type="tel" name="telefono" required class="w-full bg-surface-light border border-outline-variant rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" placeholder="Ej: 999 888 777">
        </div>
        <div class="pt-4 flex gap-3">
          <button type="button" class="flex-1 px-4 py-3 border border-outline-variant text-on-surface font-label-md rounded-xl hover:bg-surface-container transition-colors" onclick="toggleModal('addParticipantModal')">Cancelar</button>
          <button type="submit" class="flex-1 px-4 py-3 bg-primary text-on-primary font-label-md rounded-xl shadow-lg shadow-primary/20 hover:bg-primary-container transition-all active:scale-95">Guardar</button>
        </div>
      </form>
    </div>
  </div>
</div>
<!-- Edit Modal -->
<div class="fixed inset-0 z-[60] hidden" id="editModal">
  <div class="absolute inset-0 bg-on-surface/40 premium-blur" onclick="cerrarEditar()"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md p-margin-mobile">
    <div class="bg-surface-container-lowest rounded-xl shadow-2xl p-8 space-y-6">
      <div class="flex justify-between items-center">
        <h2 class="font-headline-md text-headline-md text-on-surface">Editar Participante</h2>
        <button class="text-outline hover:text-on-surface" onclick="cerrarEditar()"><span class="material-symbols-outlined">close</span></button>
      </div>
      <form id="editForm" method="POST" class="space-y-4">
        <div class="space-y-1">
          <label class="font-label-md text-label-md text-on-surface-variant ml-1">Nombre completo</label>
          <input type="text" name="nombre" id="editNombre" required class="w-full bg-surface-light border border-outline-variant rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all">
        </div>
        <div class="space-y-1">
          <label class="font-label-md text-label-md text-on-surface-variant ml-1">Teléfono <span class="text-error-alert">*</span></label>
          <input type="tel" name="telefono" id="editTelefono" required class="w-full bg-surface-light border border-outline-variant rounded-xl px-4 py-3 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all">
        </div>
        <div class="pt-4 flex gap-3">
          <button type="button" class="flex-1 px-4 py-3 border border-outline-variant text-on-surface font-label-md rounded-xl hover:bg-surface-container transition-colors" onclick="cerrarEditar()">Cancelar</button>
          <button type="submit" class="flex-1 px-4 py-3 bg-primary text-on-primary font-label-md rounded-xl shadow-lg shadow-primary/20 hover:bg-primary-container transition-all active:scale-95">Guardar cambios</button>
        </div>
      </form>
    </div>
  </div>
</div>
<script>
function toggleModal(id) {
  const modal = document.getElementById(id);
  modal.classList.toggle('hidden');
  if (!modal.classList.contains('hidden')) { document.body.style.overflow = 'hidden'; }
  else { document.body.style.overflow = ''; }
}
function editar(id, nombre, telefono) {
  document.getElementById('editForm').action = '/participantes/editar/' + id;
  document.getElementById('editNombre').value = nombre;
  document.getElementById('editTelefono').value = telefono;
  toggleModal('editModal');
}
function cerrarEditar() {
  document.getElementById('editModal').classList.add('hidden');
  document.body.style.overflow = '';
}
</script>
<%- include('footer') %>
