<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>JuntApp - <%= user ? user.nombre : 'Iniciar Sesión' %></title>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "primary": "#4648d4",
            "inverse-primary": "#c0c1ff",
            "on-primary-container": "#fffbff",
            "error-alert": "#ef4444",
            "on-surface": "#0b1c30",
            "surface-variant": "#d3e4fe",
            "surface-container-low": "#eff4ff",
            "secondary": "#49607e",
            "on-tertiary-container": "#fffbff",
            "surface-container-high": "#dce9ff",
            "on-error-container": "#93000a",
            "on-secondary-fixed-variant": "#314865",
            "error-container": "#ffdad6",
            "surface-bright": "#f8f9ff",
            "surface-dark": "#0f172a",
            "background": "#f8f9ff",
            "primary-fixed-dim": "#c0c1ff",
            "surface-container": "#e5eeff",
            "on-tertiary-fixed": "#301400",
            "tertiary-fixed": "#ffdcc5",
            "tertiary-container": "#b55d00",
            "surface-container-lowest": "#ffffff",
            "on-secondary-fixed": "#001c37",
            "on-error": "#ffffff",
            "surface": "#f8f9ff",
            "on-background": "#0b1c30",
            "secondary-container": "#c4dcff",
            "primary-fixed": "#e1e0ff",
            "outline": "#767586",
            "on-secondary": "#ffffff",
            "primary-container": "#6063ee",
            "tertiary-fixed-dim": "#ffb783",
            "success-payment": "#10b981",
            "error": "#ba1a1a",
            "surface-light": "#f8fafc",
            "secondary-fixed-dim": "#b0c8eb",
            "surface-dim": "#cbdbf5",
            "on-surface-variant": "#464554",
            "secondary-fixed": "#d2e4ff",
            "on-secondary-container": "#49617f",
            "surface-container-highest": "#d3e4fe",
            "on-primary-fixed-variant": "#2f2ebe",
            "inverse-surface": "#213145",
            "on-tertiary": "#ffffff",
            "outline-variant": "#c7c4d7",
            "inverse-on-surface": "#eaf1ff",
            "on-tertiary-fixed-variant": "#703700",
            "tertiary": "#904900",
            "on-primary-fixed": "#07006c",
            "warning-debt": "#f59e0b",
            "surface-tint": "#494bd6",
            "on-primary": "#ffffff"
          },
          borderRadius: {
            DEFAULT: "0.25rem",
            lg: "0.5rem",
            xl: "0.75rem",
            full: "9999px"
          },
          spacing: {
            "margin-desktop": "48px",
            "gutter": "24px",
            "container-max-width": "1280px",
            "margin-mobile": "16px",
            "unit": "4px"
          },
          fontFamily: {
            "headline-lg-mobile": ["Geist"],
            "label-sm": ["Geist"],
            "body-md": ["Geist"],
            "headline-lg": ["Geist"],
            "body-lg": ["Geist"],
            "label-md": ["Geist"],
            "headline-md": ["Geist"],
            "display": ["Geist"]
          },
          fontSize: {
            "headline-lg-mobile": ["28px", { lineHeight: "36px", fontWeight: "600" }],
            "label-sm": ["12px", { lineHeight: "16px", fontWeight: "600" }],
            "body-md": ["16px", { lineHeight: "24px", fontWeight: "400" }],
            "headline-lg": ["32px", { lineHeight: "40px", letterSpacing: "-0.01em", fontWeight: "600" }],
            "body-lg": ["18px", { lineHeight: "28px", fontWeight: "400" }],
            "label-md": ["14px", { lineHeight: "20px", letterSpacing: "0.01em", fontWeight: "500" }],
            "headline-md": ["24px", { lineHeight: "32px", fontWeight: "600" }],
            "display": ["48px", { lineHeight: "56px", letterSpacing: "-0.02em", fontWeight: "700" }]
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/air-datepicker@3.5.3/air-datepicker.css">
  <script src="https://cdn.jsdelivr.net/npm/air-datepicker@3.5.3/air-datepicker.js"></script>
  <link rel="stylesheet" href="/estilos.css?v=<%= Date.now() %>">
  <link rel="manifest" href="/manifest.json">
  <script>
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/sw.js');
    }
    if (localStorage.getItem('theme') === 'dark' ||
        (!localStorage.getItem('theme') && matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  </script>
  <script>
    const fLink = document.createElement('link');
    fLink.rel = 'icon';
    const isDark = document.documentElement.classList.contains('dark');
    fLink.href = isDark ? '/logo-oscuro.png' : '/logo-claro.png';
    document.head.appendChild(fLink);
    new MutationObserver(function() {
      fLink.href = document.documentElement.classList.contains('dark') ? '/logo-oscuro.png' : '/logo-claro.png';
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  </script>
  <script>
    window.toggleTheme = function() {
      var h = document.documentElement;
      h.classList.add('theme-transitioning');
      void h.offsetHeight;
      h.classList.toggle('dark');
      localStorage.setItem('theme', h.classList.contains('dark') ? 'dark' : 'light');
      setTimeout(function() { h.classList.remove('theme-transitioning'); }, 400);
    };
  </script>
  <style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
      display: inline-block;
      vertical-align: middle;
    }
    body { font-family: 'Geist', sans-serif; min-height: 100dvh; }
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
    .timeline-step-active { box-shadow: 0 0 0 4px rgba(70, 72, 212, 0.15); }
    .gradient-mesh {
      background-color: #f8f9ff;
      background-image: radial-gradient(at 0% 0%, rgba(70, 72, 212, 0.05) 0px, transparent 50%), radial-gradient(at 100% 0%, rgba(16, 185, 129, 0.05) 0px, transparent 50%);
    }
    .premium-blur { backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px); }
    html.dark .bg-surface-container-lowest { background-color: #0f172a; }
    html.dark .bg-surface-container { background-color: #334155; }
    html.dark .bg-surface { background-color: #1e293b; }
    html.dark .bg-surface-container-low { background-color: #1e293b; }
    html.dark .bg-surface-container-high { background-color: #334155; }
    html.dark .bg-surface-container-highest { background-color: #475569; }
    html.dark .bg-surface-dim { background-color: #0f172a; }
    html.dark .bg-surface-light { background-color: #1e293b; }
    html.dark .bg-surface-variant { background-color: #475569; }
    html.dark .bg-surface-bright { background-color: #0f172a; }
    html.dark .text-on-surface { color: #f1f5f9; }
    html.dark .text-on-surface-variant { color: #cbd5e1; }
    html.dark .text-primary { color: #c0c1ff; }
    html.dark .text-outline { color: #94a3b8; }
    html.dark .text-emerald-700 { color: #6ee7b7; }
    html.dark .bg-emerald-100 { background-color: #064e3b; }
    html.dark .text-on-primary { color: #ffffff; }
    html.dark .text-on-secondary-container { color: #cbd5e1; }
    html.dark .text-on-error-container { color: #fca5a5; }
    html.dark .text-error { color: #f87171; }
    html.dark .text-error-alert { color: #f87171; }
    html.dark .text-warning-debt { color: #fbbf24; }
    html.dark .text-success-payment { color: #34d399; }
    html.dark .border-outline { border-color: #64748b; }
    html.dark .border-outline-variant { border-color: #475569; }
    html.dark .border-outline-variant\/10 { border-color: rgba(71, 85, 105, 0.1); }
    html.dark .border-outline-variant\/20 { border-color: rgba(71, 85, 105, 0.2); }
    html.dark .border-outline-variant\/30 { border-color: rgba(71, 85, 105, 0.3); }
    html.dark .border-outline-variant\/40 { border-color: rgba(71, 85, 105, 0.4); }
    html.dark .border-surface-variant { border-color: #475569; }
    html.dark .border-surface-container-high { border-color: #334155; }
    html.dark .border-error-container { border-color: #7f1d1d; }
    html.dark .border-error-alert { border-color: #f87171; }
    html.dark .border-primary { border-color: #818cf8; }
    html.dark .bg-error-container { background-color: #7f1d1d; }
    html.dark .bg-success-payment { background-color: #065f46; }
    html.dark .bg-success-payment\/10 { background-color: rgba(6, 95, 70, 0.1); }
    html.dark .bg-error-container\/10 { background-color: rgba(127, 29, 29, 0.1); }
    html.dark .bg-warning-debt { background-color: #92400e; }
    html.dark .bg-warning-debt\/10 { background-color: rgba(251, 191, 36, 0.15); }
    html.dark .bg-primary\/10 { background-color: rgba(129, 140, 248, 0.1); }
    html.dark .bg-primary\/5 { background-color: rgba(129, 140, 248, 0.05); }
    html.dark .bg-primary-container { background-color: #312e81; }
    html.dark .bg-primary-container\/10 { background-color: rgba(49, 46, 129, 0.1); }
    html.dark .bg-error-container\/30 { background-color: rgba(127, 29, 29, 0.3); }
    html.dark .bg-error-container\/50 { background-color: rgba(127, 29, 29, 0.5); }
    html.dark .hover\:bg-surface-container:hover { background-color: #334155; }
    html.dark .hover\:bg-surface-container-low:hover { background-color: #1e293b; }
    html.dark .hover\:text-on-surface:hover { color: #f1f5f9; }
    html.dark .hover\:bg-surface-variant\/50:hover { background-color: rgba(71, 85, 105, 0.5); }
    html.dark .hover\:bg-error-container\/50:hover { background-color: rgba(127, 29, 29, 0.5); }
    html.dark .hover\:bg-error-container\/30:hover { background-color: rgba(127, 29, 29, 0.3); }
    html.theme-transitioning,
    html.theme-transitioning *,
    html.theme-transitioning *::before,
    html.theme-transitioning *::after {
      transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease !important;
    }
  </style>
</head>
<body class="font-body-md text-on-surface dark:text-inverse-on-surface antialiased bg-background dark:bg-surface-dark">
<% if (user) { %>
<header class="bg-surface dark:bg-surface-dark fixed top-0 w-full z-50 shadow-sm dark:shadow-none">
  <div class="flex items-center justify-between px-margin-mobile md:px-margin-desktop h-16 w-full max-w-container-max-width mx-auto">
    <div class="flex items-center gap-4">
      <div class="w-10 h-10 rounded-full bg-primary-container/10 border border-primary/10 flex items-center justify-center text-primary font-bold">
        <%= (user.nombre || 'U').charAt(0).toUpperCase() %>
      </div>
      <a href="/dashboard" class="font-display text-headline-md text-primary dark:text-inverse-primary tracking-tight">JuntApp</a>
    </div>
  </div>
</header>
<nav class="hidden md:flex fixed top-16 left-0 w-full z-40 bg-surface/80 dark:bg-surface-dark/80 premium-blur border-b border-outline-variant/20">
  <div class="flex items-center justify-around max-w-3xl mx-auto px-margin-desktop py-1.5 w-full">
    <a href="/dashboard" class="flex flex-col items-center gap-0.5 px-6 py-2 rounded-xl transition-all font-label-sm text-label-sm <%= (currentPath || '') === '/dashboard' || (currentPath || '') === '/' ? 'bg-primary/10 text-primary' : 'text-on-surface-variant hover:bg-surface-container hover:text-on-surface' %>">
      <span class="material-symbols-outlined" <%= (currentPath || '') === '/dashboard' || (currentPath || '') === '/' ? 'style="font-variation-settings: \'FILL\' 1;"' : '' %>>home</span>
      Dashboard
    </a>
    <a href="/juntas" class="flex flex-col items-center gap-0.5 px-6 py-2 rounded-xl transition-all font-label-sm text-label-sm <%= (currentPath || '') === '/juntas' || (currentPath || '').startsWith('/juntas/') ? 'bg-primary/10 text-primary' : 'text-on-surface-variant hover:bg-surface-container hover:text-on-surface' %>">
      <span class="material-symbols-outlined" <%= (currentPath || '') === '/juntas' || (currentPath || '').startsWith('/juntas/') ? 'style="font-variation-settings: \'FILL\' 1;"' : '' %>>group_work</span>
      Juntas
    </a>
    <a href="/participantes" class="flex flex-col items-center gap-0.5 px-6 py-2 rounded-xl transition-all font-label-sm text-label-sm <%= (currentPath || '') === '/participantes' ? 'bg-primary/10 text-primary' : 'text-on-surface-variant hover:bg-surface-container hover:text-on-surface' %>">
      <span class="material-symbols-outlined" <%= (currentPath || '') === '/participantes' ? 'style="font-variation-settings: \'FILL\' 1;"' : '' %>>contacts</span>
      Participantes
    </a>
    <a href="/alertas" class="flex flex-col items-center gap-0.5 px-6 py-2 rounded-xl transition-all font-label-sm text-label-sm <%= (currentPath || '') === '/alertas' ? 'bg-primary/10 text-primary' : 'text-on-surface-variant hover:bg-surface-container hover:text-on-surface' %>">
      <span class="material-symbols-outlined" <%= (currentPath || '') === '/alertas' ? 'style="font-variation-settings: \'FILL\' 1;"' : '' %>>notifications_active</span>
      Alertas
    </a>
  </div>
</nav>
<% } %>
<button onclick="toggleTheme()" class="fixed top-4 right-4 z-[100] w-10 h-10 rounded-full bg-surface-container-lowest dark:bg-surface-dark border border-outline-variant flex items-center justify-center shadow-lg hover:bg-surface-container-low active:scale-90 transition-all">
  <span class="material-symbols-outlined text-primary block dark:hidden">dark_mode</span>
  <span class="material-symbols-outlined text-primary hidden dark:block">light_mode</span>
</button>
<main class="<%= user ? 'pt-24 md:pt-36' : '' %> pb-32 px-margin-mobile md:px-margin-desktop max-w-4xl mx-auto">
