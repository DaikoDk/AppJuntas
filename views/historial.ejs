<%- include('header') %>
<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="font-headline-md text-headline-md text-on-surface">Historial</h1>
    <p class="text-on-surface-variant font-label-md"><%= junta.nombre %></p>
  </div>
  <a href="/juntas/<%= junta.id %>" class="flex items-center gap-1 px-3 py-2 rounded-xl border border-outline-variant text-primary font-label-md hover:bg-surface-container transition-colors active:scale-95">
    <span class="material-symbols-outlined" style="font-size:18px">arrow_back</span>
  </a>
</div>
<% if (historial.length === 0) { %>
<div class="mt-12 p-8 border-2 border-dashed border-outline-variant rounded-2xl flex flex-col items-center justify-center text-center">
  <div class="w-16 h-16 bg-surface-container-high rounded-full flex items-center justify-center mb-4">
    <span class="material-symbols-outlined text-outline text-[32px]">history</span>
  </div>
  <h4 class="font-headline-sm text-headline-sm text-on-surface">No hay actividad registrada</h4>
  <p class="text-on-surface-variant max-w-xs mt-2">Los pagos, eliminaciones y cesiones aparecerán aquí.</p>
</div>
<% } else { %>
<div class="space-y-3">
  <% historial.forEach(h => { %>
    <% if (h.tipo === 'pago') { %>
      <div class="bg-surface-container-lowest border border-success-payment/20 dark:border-transparent dark:bg-success-payment/5 rounded-xl p-4 flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-success-payment/10 flex items-center justify-center text-success-payment flex-shrink-0">
          <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">check_circle</span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-body-md font-medium text-on-surface"><%= h.participante_nombre %></p>
          <p class="font-label-sm text-label-sm text-on-surface-variant"><%= h.descripcion || 'Pagó S/' + h.monto.toFixed(0) %></p>
        </div>
        <div class="text-right flex-shrink-0">
          <p class="font-headline-sm text-headline-sm text-success-payment">S/ <%= h.monto.toFixed(0) %></p>
          <p class="font-label-sm text-label-sm text-outline"><%= h.fecha_pago ? new Date(h.fecha_pago).toLocaleString() : '' %></p>
        </div>
      </div>
    <% } else if (h.tipo === 'pago_eliminado') { %>
      <div class="bg-surface-container-lowest border border-error-container dark:border-transparent dark:bg-error-container/5 rounded-xl p-4 flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-error-container flex items-center justify-center text-error flex-shrink-0">
          <span class="material-symbols-outlined">undo</span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-body-md font-medium text-on-surface line-through"><%= h.participante_nombre %></p>
          <p class="font-label-sm text-label-sm text-on-surface-variant"><%= h.descripcion || 'Deshizo pago de S/' + h.monto.toFixed(0) %></p>
        </div>
        <div class="text-right flex-shrink-0">
          <p class="font-headline-sm text-headline-sm text-error-alert">-S/ <%= h.monto.toFixed(0) %></p>
          <p class="font-label-sm text-label-sm text-outline"><%= h.fecha_registro ? new Date(h.fecha_registro).toLocaleString() : '' %></p>
        </div>
      </div>
    <% } else if (h.tipo === 'cesion') { %>
      <div class="bg-surface-container-lowest border border-warning-debt/20 dark:border-transparent dark:bg-warning-debt/5 rounded-xl p-4 flex items-center gap-4">
        <div class="w-10 h-10 rounded-full bg-warning-debt/10 flex items-center justify-center text-warning-debt flex-shrink-0">
          <span class="material-symbols-outlined">swap_horiz</span>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-body-md font-medium text-on-surface">Cesión de turno</p>
          <p class="font-label-sm text-label-sm text-on-surface-variant"><%= h.descripcion || '' %></p>
        </div>
        <div class="text-right flex-shrink-0">
          <p class="font-label-sm text-label-sm text-outline"><%= new Date(h.creado_en || h.fecha_registro).toLocaleDateString() %></p>
        </div>
      </div>
    <% } %>
  <% }) %>
</div>
<% } %>
<%- include('footer') %>
